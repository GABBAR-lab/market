{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "identity-auth": {
        "ClusterId": "identity",
        "Match": { "Path": "/api/auth/{**catch-all}" }
      },
      "identity-users": {
        "ClusterId": "identity",
        "Match": { "Path": "/api/users/{**catch-all}" }
      },
      "identity-roles": {
        "ClusterId": "identity",
        "Match": { "Path": "/api/roles/{**catch-all}" }
      },
      "profile": {
        "ClusterId": "profile",
        "Match": { "Path": "/api/profiles/{**catch-all}" }
      },
      "listings": {
        "ClusterId": "listing",
        "Match": { "Path": "/api/listings/{**catch-all}" }
      },
      "categories": {
        "ClusterId": "listing",
        "Match": { "Path": "/api/categories/{**catch-all}" }
      },
      "locations": {
        "ClusterId": "listing",
        "Match": { "Path": "/api/locations/{**catch-all}" }
      },
      "listing-admin": {
        "ClusterId": "listing",
        "Match": { "Path": "/api/admin/{**catch-all}" }
      },
      "reports": {
        "ClusterId": "listing",
        "Match": { "Path": "/api/reports/{**catch-all}" }
      },
      "favorites": {
        "ClusterId": "listing",
        "Match": { "Path": "/api/favorites/{**catch-all}" }
      },
      "inquiries": {
        "ClusterId": "listing",
        "Match": { "Path": "/api/inquiries/{**catch-all}" }
      },
      "payments": {
        "ClusterId": "payment",
        "Match": { "Path": "/api/payments/{**catch-all}" }
      },
      "media-api": {
        "ClusterId": "media",
        "Match": { "Path": "/api/media/{**catch-all}" }
      },
      "uploads": {
        "ClusterId": "media",
        "Match": { "Path": "/uploads/{**catch-all}" }
      },
      "notifications": {
        "ClusterId": "notification",
        "Match": { "Path": "/api/notifications/{**catch-all}" }
      },
      "chat": {
        "ClusterId": "chat",
        "Match": { "Path": "/api/chat/{**catch-all}" }
      },
      "logs": {
        "ClusterId": "logging",
        "Match": { "Path": "/api/logs/{**catch-all}" }
      }
    },
    "Clusters": {
      "identity": {
        "Destinations": {
          "d1": { "Address": "http://localhost:5001" }
        }
      },
      "profile": {
        "Destinations": {
          "d1": { "Address": "http://localhost:5002" }
        }
      },
      "listing": {
        "Destinations": {
          "d1": { "Address": "http://localhost:5003" }
        }
      },
      "media": {
        "Destinations": {
          "d1": { "Address": "http://localhost:5004" }
        }
      },
      "payment": {
        "Destinations": {
          "d1": { "Address": "http://localhost:5005" }
        }
      },
      "notification": {
        "Destinations": {
          "d1": { "Address": "http://localhost:5006" }
        }
      },
      "chat": {
        "Destinations": {
          "d1": { "Address": "http://localhost:5007" }
        }
      },
      "logging": {
        "Destinations": {
          "d1": { "Address": "http://localhost:5008" }
        }
      }
    }
  }
}
