{
  "info": {
    "name": "MarketPlace API",
    "description": "Complete API collection for MarketPlace microservices (Identity, Profile, Listing).\n\n**Setup:**\n1. Import `MarketPlace-Local.postman_environment.json`\n2. Select environment: MarketPlace - Local\n3. Run **Auth > Login** first — token auto-saves\n4. Other protected requests use Bearer token automatically",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "identityBaseUrl",
      "value": "http://localhost:5001"
    },
    {
      "key": "profileBaseUrl",
      "value": "http://localhost:5002"
    },
    {
      "key": "listingBaseUrl",
      "value": "http://localhost:5003"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "refreshToken",
      "value": ""
    },
    {
      "key": "userId",
      "value": ""
    },
    {
      "key": "profileId",
      "value": ""
    },
    {
      "key": "listingId",
      "value": ""
    },
    {
      "key": "categoryId",
      "value": ""
    },
    {
      "key": "roleId",
      "value": ""
    },
    {
      "key": "locationId",
      "value": ""
    },
    {
      "key": "imageId",
      "value": ""
    },
    {
      "key": "addressId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "01 - Identity Service (5001)",
      "item": [
        {
          "name": "Health",
          "item": [
            {
              "name": "Health Check",
              "request": {
                "auth": {
                  "type": "noauth"
                },
                "method": "GET",
                "url": "{{identityBaseUrl}}/api/health"
              }
            }
          ]
        },
        {
          "name": "Auth",
          "item": [
            {
              "name": "Register",
              "request": {
                "auth": {
                  "type": "noauth"
                },
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"seller@example.com\",\n  \"password\": \"Seller@123\",\n  \"firstName\": \"Ali\",\n  \"lastName\": \"Khan\",\n  \"phoneNumber\": \"0771234567\"\n}"
                },
                "url": "{{identityBaseUrl}}/api/auth/register"
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "if (pm.response.code === 200) {",
                      "  const j = pm.response.json();",
                      "  pm.environment.set('accessToken', j.accessToken);",
                      "  pm.environment.set('refreshToken', j.refreshToken);",
                      "  pm.environment.set('userId', j.userId);",
                      "}"
                    ]
                  }
                }
              ]
            },
            {
              "name": "Login (Admin)",
              "request": {
                "auth": {
                  "type": "noauth"
                },
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"admin@marketplace.com\",\n  \"password\": \"Admin@123\"\n}"
                },
                "url": "{{identityBaseUrl}}/api/auth/login"
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "if (pm.response.code === 200) {",
                      "  const j = pm.response.json();",
                      "  pm.environment.set('accessToken', j.accessToken);",
                      "  pm.environment.set('refreshToken', j.refreshToken);",
                      "  pm.environment.set('userId', j.userId);",
                      "}"
                    ]
                  }
                }
              ]
            },
            {
              "name": "Refresh Token",
              "request": {
                "auth": {
                  "type": "noauth"
                },
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
                },
                "url": "{{identityBaseUrl}}/api/auth/refresh-token"
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "if (pm.response.code === 200) {",
                      "  const j = pm.response.json();",
                      "  pm.environment.set('accessToken', j.accessToken);",
                      "  pm.environment.set('refreshToken', j.refreshToken);",
                      "}"
                    ]
                  }
                }
              ]
            },
            {
              "name": "Logout",
              "request": {
                "auth": {
                  "type": "noauth"
                },
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
                },
                "url": "{{identityBaseUrl}}/api/auth/logout"
              }
            }
          ]
        },
        {
          "name": "Users",
