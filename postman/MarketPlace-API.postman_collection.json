                "method": "POST",
                "url": "{{identityBaseUrl}}/api/users/{{userId}}/suspend"
              }
            },
            {
              "name": "Activate User (Admin)",
              "request": {
                "method": "POST",
                "url": "{{identityBaseUrl}}/api/users/{{userId}}/activate"
              }
            },
            {
              "name": "Assign Role (Admin)",
              "request": {
                "method": "POST",
                "url": "{{identityBaseUrl}}/api/users/{{userId}}/roles/{{roleId}}"
              }
            },
            {
              "name": "Remove Role (Admin)",
              "request": {
                "method": "DELETE",
                "url": "{{identityBaseUrl}}/api/users/{{userId}}/roles/{{roleId}}"
              }
            }
          ]
        },
        {
          "name": "Roles",
          "item": [
            {
              "name": "Get All Roles",
              "request": {
                "auth": {
                  "type": "noauth"
                },
                "method": "GET",
                "url": "{{identityBaseUrl}}/api/roles"
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "if (pm.response.code === 200) {",
                      "  const roles = pm.response.json();",
                      "  const seller = roles.find(r => r.name === 'Seller');",
                      "  if (seller) pm.environment.set('roleId', seller.id);",
                      "}"
                    ]
                  }
                }
              ]
            },
            {
              "name": "Get Role By Id",
              "request": {
                "auth": {
                  "type": "noauth"
                },
                "method": "GET",
                "url": "{{identityBaseUrl}}/api/roles/{{roleId}}"
              }
            },
            {
              "name": "Create Role (Admin)",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"Moderator\",\n  \"description\": \"Content moderator\"\n}"
                },
                "url": "{{identityBaseUrl}}/api/roles"
              }
            },
            {
              "name": "Update Role (Admin)",
              "request": {
                "method": "PUT",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"Moderator\",\n  \"description\": \"Updated description\"\n}"
                },
                "url": "{{identityBaseUrl}}/api/roles/{{roleId}}"
              }
            }
          ]
        }
      ]
    },
