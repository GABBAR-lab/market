                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"firstName\": \"Updated\",\n  \"lastName\": \"Name\",\n  \"phoneNumber\": \"0779999999\"\n}"
                },
                "url": "{{identityBaseUrl}}/api/users/{{userId}}"
              }
